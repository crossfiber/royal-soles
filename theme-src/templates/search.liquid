<main>
  <div class="wrap">
    <div class="search-wrap">
      <form action="/search" method="get" class="search-bar">
        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search brand, model, colorway" autofocus>
        <input type="hidden" name="type" value="product">
      </form>
      {% if search.performed %}
      {% paginate search.results by 24 %}
      <div class="grid" style="margin-top:18px">
        {% for item in search.results %}
          {% if item.object_type == 'product' %}{% render 'product-card', product: item %}{% endif %}
        {% else %}<div class="empty">No matches. Try a brand, model, or size.</div>{% endfor %}
      </div>
      {% if paginate.pages > 1 %}<div class="toolbar">{{ paginate | default_pagination }}</div>{% endif %}
      {% endpaginate %}
      {% endif %}
    </div>
  </div>
</main>